    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Traj_Gen (C++)",
            "type": "cppdbg",
            "request": "launch",
            //ROS 1 path
            "program": "${workspaceFolder}/devel/lib/cav_traj_gen/cav_traj_gen",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {"description": "Enable pretty printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
            }
            ]
    },
    {
        "name": "ROS Launch",
        "type": "ros2",
        "request": "launch",
        "target": "${workspaceFolder}/src/cav_traj_gen/launch/cav_traj_gen.launch"
    }
    

    ]
}